{
  "version": 2,
  "builds": [
    {
      "src": "api/dify-proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/dify-proxy",
      "dest": "/api/dify-proxy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
